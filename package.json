{
  "name": "marketing-assistant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"node server/index.cjs\" \"vite\"",
    "dev:server": "node server/index.cjs",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "serverless-http": "^4.0.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.3.1"
  }
}
